# MCP Bridge Configuration
PORT=3001
MCP_BEARER_TOKEN=your-secret-token-here

# Actual Budget Server (PikaPods or Render)
ACTUAL_SERVER_URL=https://your-pikapod-url.pikapods.com:5006
ACTUAL_BUDGET_ID=your-budget-id-here
ACTUAL_PASSWORD=your-actual-password
ACTUAL_DATA_DIR=/tmp/actual-data

# Web App Configuration (for Vite)
VITE_MCP_BRIDGE_URL=https://your-mcp-bridge.onrender.com
VITE_MCP_BEARER_TOKEN=your-secret-token-here
